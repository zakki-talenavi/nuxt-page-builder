{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://puck/workflow-definition.json",
  "title": "WorkflowDefinition",
  "description": "JSON schema for workflow definition (DAG). Persisted as-is; Vue Flow is the editor view.",
  "type": "object",
  "required": ["id", "name", "version", "nodes", "edges"],
  "properties": {
    "id": { "type": "string", "description": "Unique workflow id" },
    "name": { "type": "string", "description": "Display name" },
    "description": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "status": { "enum": ["draft", "published"] },
    "publishedAt": { "type": "string", "format": "date-time" },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/WorkflowNode" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/WorkflowEdge" }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "WorkflowNode": {
      "type": "object",
      "required": ["id", "type", "config"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "description": "Node type key (e.g. form_submitted, if_else, send_email)" },
        "position": { "$ref": "#/$defs/XYPosition" },
        "config": { "type": "object", "additionalProperties": true },
        "meta": { "$ref": "#/$defs/NodeMeta" }
      }
    },
    "WorkflowEdge": {
      "type": "object",
      "required": ["id", "source", "target"],
      "properties": {
        "id": { "type": "string" },
        "source": { "type": "string", "description": "Source node id" },
        "target": { "type": "string", "description": "Target node id" },
        "sourceHandle": { "type": ["string", "null"], "description": "For conditions: 'true' | 'false' or branch key" }
      }
    },
    "XYPosition": {
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "NodeMeta": {
      "type": "object",
      "properties": {
        "timeoutMs": { "type": "integer" },
        "retryPolicy": {
          "type": "object",
          "properties": {
            "maxAttempts": { "type": "integer" },
            "backoffMs": { "type": "integer" },
            "backoffMultiplier": { "type": "number" }
          }
        }
      }
    }
  }
}
